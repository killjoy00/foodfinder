# Copy to .env.local for local development. All variables are optional —
# without them the app runs in demo mode with sample data.

# Supabase (Project Settings → API). Required for real, persistent data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to sign the group-login cookie so it can't be tampered with.
# Set this in production (any long random string). Falls back to CRON_SECRET.
AUTH_SECRET=

# Google Places API key. Unlocks autocomplete when adding restaurants,
# the weekly new-restaurant sweep, and recommendations.
GOOGLE_PLACES_API_KEY=

# Any random string. Protects the cron endpoints; Vercel sends it automatically.
CRON_SECRET=

# Owner access to /admin (see who signed up, reset group passwords, edit the
# master catalog). Any long random string; leave unset to disable admin.
ADMIN_SECRET=

# Note: login is now per-group (group name + password, stored in the
# database). The old FAMILY_PASSWORD is no longer used.
