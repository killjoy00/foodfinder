# Copy to .env.local for local development. All variables are optional —
# without them the app runs in demo mode with sample data.

# Supabase (Project Settings → API). Required for real, persistent data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The shared password the family types to get in. Leave unset = no gate.
FAMILY_PASSWORD=

# Google Places API key. Unlocks autocomplete when adding restaurants,
# the weekly new-restaurant sweep, and recommendations.
GOOGLE_PLACES_API_KEY=

# Any random string. Protects the cron endpoints; Vercel sends it automatically.
CRON_SECRET=
